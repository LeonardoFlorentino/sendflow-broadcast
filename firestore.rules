rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerOf(data) {
      return isSignedIn() && data.clientId == request.auth.uid;
    }

    match /connections/{connectionId} {
      allow read: if isOwnerOf(resource.data);
      allow create: if isOwnerOf(request.resource.data);
      allow update: if isOwnerOf(resource.data) && isOwnerOf(request.resource.data);
      allow delete: if isOwnerOf(resource.data);
    }

    match /contacts/{contactId} {
      allow read: if isOwnerOf(resource.data);
      allow create: if isOwnerOf(request.resource.data);
      allow update: if isOwnerOf(resource.data) && isOwnerOf(request.resource.data);
      allow delete: if isOwnerOf(resource.data);
    }

    match /messages/{messageId} {
      allow read: if isOwnerOf(resource.data);
      allow create: if isOwnerOf(request.resource.data)
        && request.resource.data.status == 'scheduled';
      allow update: if isOwnerOf(resource.data)
        && isOwnerOf(request.resource.data)
        && resource.data.status == 'scheduled';
      allow delete: if isOwnerOf(resource.data);
    }
  }
}
